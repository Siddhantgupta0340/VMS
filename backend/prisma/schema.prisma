model GoodsReceiptItem {
  id                   String   @id @default(uuid())
  goods_receipt_note_id String
  purchase_order_id    String
  item_name            String
  description          String?
  ordered_quantity     Decimal  @default(0) @db.Decimal(14, 3)
  received_quantity    Decimal  @default(0) @db.Decimal(14, 3)
  accepted_quantity    Decimal  @default(0) @db.Decimal(14, 3)
  rejected_quantity    Decimal  @default(0) @db.Decimal(14, 3)
  unit_price           Decimal  @default(0) @db.Decimal(14, 2)
  gst_amount           Decimal  @default(0) @db.Decimal(14, 2)
  line_total           Decimal  @default(0) @db.Decimal(14, 2)
  remarks              String?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  goods_receipt_note GoodsReceiptNote @relation(fields: [goods_receipt_note_id], references: [id], onDelete: Cascade)
  purchase_order     PurchaseOrder    @relation(fields: [purchase_order_id], references: [id])

  @@index([goods_receipt_note_id])
  @@index([purchase_order_id])
  @@map("goods_receipt_items")
}

model DeliveryChallan {
  id                        String    @id @default(uuid())
  delivery_challan_number   String    @unique
  vendor_id                 String
  purchase_order_id         String
  created_by_id             String?
  status                    String    @default("created")

  vendor_name     String?
  vendor_code     String?
  gst_number      String?
  delivery_date   DateTime?
  delivery_address String?
  transporter     String?
  vehicle_number  String?
  driver_name     String?
  driver_contact  String?
  delivery_status String @default("CREATED")
  document_url    String?
  document_name   String?
  vehicle_details String?
  currency        String    @default("INR")
  subtotal        Decimal   @default(0) @db.Decimal(14, 2)
  gst_amount      Decimal   @default(0) @db.Decimal(14, 2)
  total_amount    Decimal   @default(0) @db.Decimal(14, 2)
  line_items      Json?
  items           DeliveryChallanItem[]
  remarks         String?
  deleted_at      DateTime?
  deleted_by_id   String?
  delete_reason   String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  vendor            Vendor          @relation(fields: [vendor_id], references: [id])
  purchase_order    PurchaseOrder   @relation(fields: [purchase_order_id], references: [id])
  created_by        User?           @relation("DeliveryChallanCreatedBy", fields: [created_by_id], references: [id])
  goods_receipt_notes GoodsReceiptNote[]
  three_way_matches ThreeWayMatch[]

  @@index([vendor_id])
  @@index([purchase_order_id])
  @@index([status])
  @@map("delivery_challans")
}

