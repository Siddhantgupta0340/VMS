generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
// Roles: SUPER_ADMIN | CASE_MANAGER | TEAM_LEAD | MANAGER | FINANCE_HEAD
// ─────────────────────────────────────────────────────────────────────────────
model User {
  id                         String    @id @default(uuid())
  email                      String    @unique
  password                   String
  role                       String    // SUPER_ADMIN | CASE_MANAGER | TEAM_LEAD | MANAGER | FINANCE_HEAD
  first_name                 String?
  last_name                  String?
  status                     String    @default("ACTIVE")
  status_changed_at          DateTime?
  status_changed_by          String?
  updated_by                 String?
  deleted_at                 DateTime?
  last_login_at              DateTime?
  refresh_token              String?
  password_reset_otp         String?
  password_reset_otp_expires DateTime?
  created_at                 DateTime  @default(now())
  updated_at                 DateTime  @updatedAt

  // Vendor relations
  vendors_created            Vendor[]        @relation("VendorCreatedBy")
  vendors_approved           Vendor[]        @relation("VendorApprovedBy")

  // Purchase Order relations
  purchase_orders_created    PurchaseOrder[] @relation("PurchaseOrderCreatedBy")

  // Invoice relations
  invoices_created           Invoice[]       @relation("InvoiceCreatedBy")
  invoices_updated           Invoice[]       @relation("InvoiceUpdatedBy")
  invoices_team_lead_approved  Invoice[]     @relation("InvoiceTeamLeadApprovedBy")
  invoices_manager_approved    Invoice[]     @relation("InvoiceManagerApprovedBy")
  invoices_finance_head_approved Invoice[]   @relation("InvoiceFinanceHeadApprovedBy")
  invoices_rejected            Invoice[]     @relation("InvoiceRejectedBy")
  invoices_deleted             Invoice[]     @relation("InvoiceDeletedBy")

  // Three-Way Matching relations
  matching_completed           ThreeWayMatch[] @relation("MatchingCompletedBy")
  matching_reviewed            ThreeWayMatch[] @relation("MatchingAdminReviewedBy")

  // Admin Review relations
  admin_reviews_done           Invoice[]       @relation("InvoiceAdminReviewedBy")

  // GRN relations
  grns_created                 GoodsReceiptNote[] @relation("GRNCreatedBy")

  // Payment relations
  payments_created             Payment[]       @relation("PaymentCreatedBy")
  payments_approved            Payment[]       @relation("PaymentApprovedBy")
  payments_processed           Payment[]       @relation("PaymentProcessedBy")
  payments_updated             Payment[]       @relation("PaymentUpdatedBy")

  // Legacy payment relations (kept for migration safety)
  payments_created_old         PaymentOld[]    @relation("PaymentOldCreatedBy")
  payments_approved_old        PaymentOld[]    @relation("PaymentOldApprovedBy")
  payments_rejected_old        PaymentOld[]    @relation("PaymentOldRejectedBy")
  payments_blocked_old         PaymentOld[]    @relation("PaymentOldBlockedBy")

  // Audit & Notification relations
  approval_logs                AuditLog[]      @relation("AuditLogPerformedBy")
  legacy_approval_logs         ApprovalLog[]   @relation("ApprovalLogPerformedBy")
  notifications                Notification[]  @relation("NotificationRecipient")

  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// VENDOR
// Created by Case Manager, reviewed/approved by Finance Head
// ─────────────────────────────────────────────────────────────────────────────
model Vendor {
  id              String    @id @default(uuid())
  name            String
  vendor_code     String    @unique
  email           String    @unique
  phone           String
  address         String
  city            String?
  state           String?
  zip_code        String?
  tax_id          String    @unique
  gst_number      String?
  category        String
  contact_person  String?
  bank_account_no String?
  ifsc_code       String?
  payment_terms   String?
  billing_address String?
  delivery_address String?
  status          String    @default("pending")   // pending | approved | rejected | blocked
  created_by_id   String?
  approved_by_id  String?
  approved_at     DateTime?
  rejected_at     DateTime?
  blocked_at      DateTime?
  is_active       Boolean   @default(true)
  deleted_at      DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  created_by      User?           @relation("VendorCreatedBy",  fields: [created_by_id],  references: [id])
  approved_by     User?           @relation("VendorApprovedBy", fields: [approved_by_id], references: [id])
  purchase_orders PurchaseOrder[]
  invoices        Invoice[]
  payments        Payment[]
  grns            GoodsReceiptNote[]

  @@index([status])
  @@index([created_by_id])
  @@map("vendors")
}

// ─────────────────────────────────────────────────────────────────────────────
// PURCHASE ORDER
// ─────────────────────────────────────────────────────────────────────────────
model PurchaseOrder {
  id                     String    @id @default(uuid())
  po_number              String    @unique
  vendor_id              String
  created_by_id          String?
  amount                 Decimal   @db.Decimal(14, 2)
  currency               String    @default("INR")
  status                 String    @default("pending")  // pending | open | closed | cancelled
  description            String?
  delivery_terms         String?
  payment_terms          String?
  billing_address        String?
  delivery_address       String?
  order_date             DateTime  @default(now())
  expected_delivery_date DateTime?
  closed_at              DateTime?
  cancelled_at           DateTime?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt

  // Line items (stored as JSON for flexibility)
  line_items             Json?

  vendor     Vendor    @relation(fields: [vendor_id],     references: [id])
  created_by User?     @relation("PurchaseOrderCreatedBy", fields: [created_by_id], references: [id])
  invoices   Invoice[]
  payments   Payment[]
  grns       GoodsReceiptNote[]
  three_way_matches ThreeWayMatch[]

  @@index([vendor_id])
  @@index([status])
  @@map("purchase_orders")
}

// ─────────────────────────────────────────────────────────────────────────────
// GOODS RECEIPT NOTE (GRN)
// Created when goods are physically received from vendor
// ─────────────────────────────────────────────────────────────────────────────
model GoodsReceiptNote {
  id                  String    @id @default(uuid())
  grn_number          String    @unique
  vendor_id           String
  purchase_order_id   String
  created_by_id       String?
  status              String    @default("draft")    // draft | verified | rejected

  // Core GRN fields
  vendor_name         String?
  vendor_code         String?
  gst_number          String?

  // Delivery info
  delivery_date       DateTime?
  delivery_challan_no String?
  delivery_address    String?
  billing_address     String?
  delivery_terms      String?

  // Financial fields
  currency            String    @default("INR")
  subtotal            Decimal   @default(0) @db.Decimal(14, 2)
  gst_amount          Decimal   @default(0) @db.Decimal(14, 2)
  discount            Decimal   @default(0) @db.Decimal(14, 2)
  total_amount        Decimal   @default(0) @db.Decimal(14, 2)
  payment_terms       String?

  // Line items (stored as JSON)
  line_items          Json?

  remarks             String?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  vendor               Vendor        @relation(fields: [vendor_id],           references: [id])
  purchase_order       PurchaseOrder @relation(fields: [purchase_order_id],   references: [id])
  created_by           User?         @relation("GRNCreatedBy", fields: [created_by_id], references: [id])
  three_way_matches    ThreeWayMatch[]

  @@index([vendor_id])
  @@index([purchase_order_id])
  @@map("goods_receipt_notes")
}

// ─────────────────────────────────────────────────────────────────────────────
// INVOICE
// Central entity — drives the approval workflow
// ─────────────────────────────────────────────────────────────────────────────
model Invoice {
  id                     String    @id @default(uuid())
  invoice_number         String    @unique
  vendor_id              String
  purchase_order_id      String
  created_by_id          String?
  updated_by_id          String?

  // Amounts
  amount                 Decimal   @db.Decimal(14, 2)
  currency               String    @default("INR")
  invoice_total          Decimal   @default(0.00) @db.Decimal(14, 2)
  paid_amount            Decimal   @default(0.00) @db.Decimal(14, 2)
  remaining_amount       Decimal   @default(0.00) @db.Decimal(14, 2)

  // Approval workflow
  status                 String    @default("PENDING_THREE_WAY_MATCH")
  required_approval_role String    // TEAM_LEAD | MANAGER | FINANCE_HEAD
  current_approval_level String?   // TEAM_LEAD | MANAGER | FINANCE_HEAD | null

  // Payment status
  payment_status         String    @default("UNPAID")
  last_payment_date      DateTime?
  last_payment_id        String?

  // ── Three-Way Matching ──────────────────────────────────────
  three_way_match_status     String?   // PENDING | MATCHED | UNMATCHED | SKIPPED
  three_way_match_percentage Decimal?  @db.Decimal(5, 2)
  matching_completed_by_id   String?
  matching_completed_at      DateTime?
  matching_remarks           String?

  // ── Admin Review ────────────────────────────────────────────
  admin_review_status    String?   // PENDING | APPROVED | REJECTED
  admin_reviewed_by_id   String?
  admin_reviewed_at      DateTime?
  admin_remarks          String?

  // ── Team Lead (formerly L1) Approval ────────────────────────
  team_lead_approver_id  String?
  team_lead_approved_at  DateTime?
  team_lead_remarks      String?

  // ── Manager (formerly L2) Approval ──────────────────────────
  manager_approver_id    String?
  manager_approved_at    DateTime?
  manager_remarks        String?

  // ── Finance Head (formerly L3) Approval ─────────────────────
  finance_head_approver_id  String?
  finance_head_approved_at  DateTime?
  finance_head_remarks      String?

  // ── Final State ──────────────────────────────────────────────
  final_approved_at      DateTime?
  rejected_by_id         String?
  rejected_at            DateTime?
  rejection_reason       String?
  cancelled_at           DateTime?

  // ── Soft Delete ──────────────────────────────────────────────
  deleted_at             DateTime?
  deleted_by_id          String?
  delete_reason          String?

  // Dates & Meta
  invoice_date           DateTime  @default(now())
  due_date               DateTime?
  description            String?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt

  // ── Relations ────────────────────────────────────────────────
  vendor         Vendor        @relation(fields: [vendor_id],          references: [id])
  purchase_order PurchaseOrder @relation(fields: [purchase_order_id],  references: [id])

  created_by     User?         @relation("InvoiceCreatedBy",            fields: [created_by_id],           references: [id])
  updated_by     User?         @relation("InvoiceUpdatedBy",            fields: [updated_by_id],           references: [id])
  team_lead_approver   User?   @relation("InvoiceTeamLeadApprovedBy",   fields: [team_lead_approver_id],   references: [id])
  manager_approver     User?   @relation("InvoiceManagerApprovedBy",    fields: [manager_approver_id],      references: [id])
  finance_head_approver User?  @relation("InvoiceFinanceHeadApprovedBy",fields: [finance_head_approver_id], references: [id])
  rejected_by    User?         @relation("InvoiceRejectedBy",           fields: [rejected_by_id],          references: [id])
  deleted_by     User?         @relation("InvoiceDeletedBy",            fields: [deleted_by_id],           references: [id])
  admin_reviewed_by User?      @relation("InvoiceAdminReviewedBy",      fields: [admin_reviewed_by_id],    references: [id])

  payments       Payment[]
  payments_old   PaymentOld[]
  three_way_matches ThreeWayMatch[]

  @@index([status])
  @@index([vendor_id])
  @@index([purchase_order_id])
  @@index([required_approval_role, status])
  @@index([deleted_at])
  @@map("invoices")
}

// ─────────────────────────────────────────────────────────────────────────────
// THREE-WAY MATCH
// Comparison record between PO, GRN, and Invoice
// ─────────────────────────────────────────────────────────────────────────────
model ThreeWayMatch {
  id                    String    @id @default(uuid())
  invoice_id            String
  purchase_order_id     String
  grn_id                String?

  // Match result
  status                String    @default("PENDING")  // PENDING | MATCHED | UNMATCHED
  match_percentage      Decimal   @default(0) @db.Decimal(5, 2)
  matched_fields_count  Int       @default(0)
  total_fields_count    Int       @default(0)
  unmatched_fields      Json?     // Array of { field, poValue, grnValue, invoiceValue }
  matched_fields        Json?     // Array of matched field names
  warnings              Json?     // Partial matches / warnings

  // Approval recommendation
  approval_recommendation String? // APPROVE | REJECT | REVIEW

  // Snapshot data (stored at time of matching)
  po_snapshot           Json?     // PO data at matching time
  grn_snapshot          Json?     // GRN data at matching time
  invoice_snapshot      Json?     // Invoice data at matching time

  // Completion tracking
  completed_by_id       String?
  completed_at          DateTime?
  remarks               String?

  // Admin review
  admin_review_status   String?   // PENDING | APPROVED | REJECTED
  admin_reviewed_by_id  String?
  admin_reviewed_at     DateTime?
  admin_remarks         String?

  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  invoice        Invoice       @relation(fields: [invoice_id],         references: [id])
  purchase_order PurchaseOrder @relation(fields: [purchase_order_id],  references: [id])
  grn            GoodsReceiptNote? @relation(fields: [grn_id],         references: [id])
  completed_by   User?         @relation("MatchingCompletedBy",      fields: [completed_by_id],       references: [id])
  admin_reviewed_by User?      @relation("MatchingAdminReviewedBy",  fields: [admin_reviewed_by_id],  references: [id])

  @@index([invoice_id])
  @@index([status])
  @@map("three_way_matches")
}

// ─────────────────────────────────────────────────────────────────────────────
// PAYMENT (Rebuilt multi-payment model)
// ─────────────────────────────────────────────────────────────────────────────
model Payment {
  id                      String    @id @default(uuid())
  payment_number          String    @unique
  invoice_id              String
  vendor_id               String
  purchase_order_id       String
  amount                  Decimal   @db.Decimal(14, 2)
  currency                String    @default("INR")
  status                  String    @default("PENDING")
  payment_method          String?
  payment_type            String    @default("FULL")
  payment_provider        String    @default("MANUAL")
  provider_transaction_id String?
  gateway_reference       String?
  payment_gateway_response Json?
  gateway_status          String?
  response_message        String?
  payment_date            DateTime?
  due_date                DateTime?
  remarks                 String?

  processed_by_id         String?
  approved_by_id          String?
  created_by_id           String?
  updated_by_id           String?

  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  invoice        Invoice        @relation(fields: [invoice_id],         references: [id])
  vendor         Vendor         @relation(fields: [vendor_id],          references: [id])
  purchase_order PurchaseOrder  @relation(fields: [purchase_order_id],  references: [id])

  processed_by   User?          @relation("PaymentProcessedBy", fields: [processed_by_id], references: [id])
  approved_by    User?          @relation("PaymentApprovedBy",  fields: [approved_by_id],  references: [id])
  created_by     User?          @relation("PaymentCreatedBy",   fields: [created_by_id],   references: [id])
  updated_by     User?          @relation("PaymentUpdatedBy",   fields: [updated_by_id],   references: [id])

  @@index([status])
  @@index([invoice_id])
  @@index([vendor_id])
  @@index([purchase_order_id])
  @@map("payments")
}

// Keeping the old payment model for migration safety
model PaymentOld {
  id             String    @id @default(uuid())
  invoice_id     String    @unique
  created_by_id  String?
  amount         Decimal   @db.Decimal(14, 2)
  currency       String    @default("INR")
  status         String    @default("pending")
  payment_method String?
  reference_no   String?
  notes          String?
  approved_by_id String?
  rejected_by_id String?
  blocked_by_id  String?
  approved_at    DateTime?
  rejected_at    DateTime?
  blocked_at     DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  invoice     Invoice @relation(fields: [invoice_id],    references: [id])
  created_by  User?   @relation("PaymentOldCreatedBy",  fields: [created_by_id],  references: [id])
  approved_by User?   @relation("PaymentOldApprovedBy", fields: [approved_by_id], references: [id])
  rejected_by User?   @relation("PaymentOldRejectedBy", fields: [rejected_by_id], references: [id])
  blocked_by  User?   @relation("PaymentOldBlockedBy",  fields: [blocked_by_id],  references: [id])

  @@map("payments_old")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDIT LOG (Enhanced — replaces ApprovalLog)
// Tracks every action with IP, browser, old/new values
// ─────────────────────────────────────────────────────────────────────────────
model AuditLog {
  id              String   @id @default(uuid())
  entity_type     String   // invoice | vendor | payment | grn | three_way_match | user
  entity_id       String
  action          String   // submitted | approved | rejected | cancelled | deleted | restored | matching_started | ...
  from_status     String?
  to_status       String?
  performed_by_id String?
  remarks         String?
  old_value       Json?    // Snapshot of entity before change
  new_value       Json?    // Snapshot of entity after change
  ip_address      String?
  user_agent      String?
  created_at      DateTime @default(now())

  performed_by User? @relation("AuditLogPerformedBy", fields: [performed_by_id], references: [id])

  @@index([entity_type, entity_id])
  @@index([performed_by_id])
  @@index([created_at])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// LEGACY APPROVAL LOG (kept for backward compat — do not remove)
// ─────────────────────────────────────────────────────────────────────────────
model ApprovalLog {
  id              String   @id @default(uuid())
  entity_type     String
  entity_id       String
  action          String
  from_status     String?
  to_status       String?
  performed_by_id String?
  remarks         String?
  created_at      DateTime @default(now())

  performed_by User? @relation("ApprovalLogPerformedBy", fields: [performed_by_id], references: [id])

  @@index([entity_type, entity_id])
  @@index([performed_by_id])
  @@map("approval_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────────────────────────────────────────
model Notification {
  id          String    @id @default(uuid())
  user_id     String
  title       String
  message     String
  type        String
  entity_type String?
  entity_id   String?
  is_read     Boolean   @default(false)
  read_at     DateTime?
  created_at  DateTime  @default(now())

  user User @relation("NotificationRecipient", fields: [user_id], references: [id])

  @@index([user_id, is_read])
  @@index([user_id, created_at])
  @@map("notifications")
}
